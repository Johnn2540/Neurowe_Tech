<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>About Us - NeurowexTech</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- AOS -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --blue: #2563eb;
            --orange: #f97316;
            --dark: #050b18;
            --dark-2: #0d1526;
            --light: #f8fafc;
            --light-2: #e2e8f0;
            --text: #334155;
            --text-light: #94a3b8;
            --grad-blue: linear-gradient(135deg, #2563eb, #1d4ed8);
            --font-head: 'Syne', sans-serif;
            --font-body: 'Inter', sans-serif;
            --radius: 20px;
            --radius-sm: 12px;
            --transition: all 0.35s ease;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: var(--font-body);
            background: var(--light);
            color: var(--text);
            overflow-x: hidden;
        }
        h1, h2, h3, h4, h5 { font-family: var(--font-head); }

        /* Navbar */
        .navbar {
            background: rgba(255,255,255,0.98);
            backdrop-filter: blur(16px);
            box-shadow: 0 2px 20px rgba(0,0,0,0.05);
            padding: 0.8rem 0;
            transition: var(--transition);
        }
        .navbar.scrolled { padding: 0.5rem 0; }
        .navbar-brand {
            font-size: 1.5rem;
            font-weight: 800;
            background: var(--grad-blue);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        .navbar-brand span { color: var(--orange); background: none; }
        .nav-link {
            font-weight: 500;
            color: var(--text) !important;
            transition: var(--transition);
        }
        .nav-link:hover { color: var(--blue) !important; }

        /* Page Header */
        .page-header {
            background: var(--grad-blue);
            padding: 120px 0 60px;
            color: white;
            text-align: center;
        }
        .page-header h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 15px; }
        .page-header p { opacity: 0.85; font-size: 1rem; max-width: 600px; margin: 0 auto; }

        /* Content Sections */
        .about-section {
            padding: 60px 0;
        }
        .about-card {
            background: white;
            border-radius: var(--radius);
            padding: 40px;
            height: 100%;
            border: 1px solid var(--light-2);
            transition: var(--transition);
        }
        .about-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        }
        .about-icon {
            width: 70px;
            height: 70px;
            background: rgba(37,99,235,0.1);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
            font-size: 2rem;
            color: var(--blue);
        }
        .stats-card {
            background: white;
            border-radius: var(--radius);
            padding: 30px;
            text-align: center;
            border: 1px solid var(--light-2);
            transition: var(--transition);
        }
        .stats-card:hover {
            transform: translateY(-5px);
        }
        .stats-number {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--blue);
        }
        .team-member {
            background: white;
            border-radius: var(--radius);
            padding: 30px;
            text-align: center;
            border: 1px solid var(--light-2);
            transition: var(--transition);
        }
        .team-member:hover {
            transform: translateY(-5px);
        }
        .team-avatar {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            margin: 0 auto 20px;
            overflow: hidden;
        }
        .team-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .back-home {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--grad-blue);
            color: white;
            padding: 12px 28px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            transition: var(--transition);
            margin-top: 30px;
        }
        .back-home:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(37,99,235,0.3);
            color: white;
        }

        /* Footer */
        footer {
            background: var(--dark);
            color: rgba(255,255,255,0.7);
            padding: 60px 0 30px;
            margin-top: 60px;
        }
        footer h4, footer h5 { color: white; margin-bottom: 1rem; font-family: var(--font-head); }
        footer a { color: rgba(255,255,255,0.55); text-decoration: none; transition: var(--transition); }
        footer a:hover { color: var(--orange); }
        footer ul li { padding: 4px 0; }
        .footer-divider { border-color: rgba(255,255,255,0.08); margin: 32px 0 24px; }
        .footer-bottom { color: rgba(255,255,255,0.4); font-size: 0.82rem; }
        .social-btn {
            width: 38px; height: 38px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(255,255,255,0.07);
            color: white;
            transition: var(--transition);
            font-size: 0.9rem;
        }
        .social-btn:hover { background: var(--blue); color: white; transform: translateY(-3px); }
        .footer-logo-img { max-width: 160px; height: auto; }

        /* Dark Mode */
        body.dark {
            background: var(--dark);
            color: var(--light);
        }
        body.dark .navbar { background: rgba(5,11,24,0.98) !important; }
        body.dark .about-card,
        body.dark .stats-card,
        body.dark .team-member {
            background: var(--dark-2);
            border-color: rgba(255,255,255,0.08);
        }
        body.dark .about-card p,
        body.dark .stats-card p,
        body.dark .team-member p {
            color: var(--text-light);
        }
        body.dark footer { background: var(--dark-2); }

        /* Responsive */
        @media (max-width: 768px) {
            .page-header { padding: 100px 0 40px; }
            .page-header h1 { font-size: 1.8rem; }
            .about-card { padding: 24px; }
            .stats-number { font-size: 1.8rem; }
            .team-avatar { width: 100px; height: 100px; }
        }
    </style>
</head>
