<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Sign In - NeurowexTech</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --blue: #2563eb;
            --orange: #f97316;
            --dark: #050b18;
            --dark-2: #0d1526;
            --dark-3: #111827;
            --light: #f8fafc;
            --light-2: #e2e8f0;
            --text: #334155;
            --text-light: #94a3b8;
            --grad-blue: linear-gradient(135deg, #2563eb, #1d4ed8);
            --font-head: 'Syne', sans-serif;
            --font-body: 'Inter', sans-serif;
            --radius: 20px;
            --radius-sm: 12px;
            --transition: all 0.35s ease;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: var(--font-body);
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }

        .back-home {
            position: fixed;
            top: 30px;
            left: 30px;
            z-index: 1000;
        }
        .back-home a {
            background: rgba(255,255,255,0.2);
            backdrop-filter: blur(10px);
            color: white;
            padding: 10px 20px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .back-home a:hover {
            background: white;
            color: var(--blue);
            transform: translateY(-2px);
        }

        .signin-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 80px 20px;
        }
        .signin-card {
            background: white;
            border-radius: var(--radius);
            box-shadow: 0 25px 50px rgba(0,0,0,0.2);
            overflow: hidden;
            max-width: 480px;
            width: 100%;
            animation: fadeInUp 0.6s ease;
        }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .signin-header {
            background: var(--grad-blue);
            padding: 40px 30px;
            text-align: center;
            color: white;
        }
        .signin-header h1 { font-family: var(--font-head); font-size: 1.8rem; margin-bottom: 8px; }
        .signin-header p { opacity: 0.85; font-size: 0.9rem; }
        .signin-body { padding: 40px 30px; }
        
        .form-group { margin-bottom: 25px; }
        .form-group label { font-weight: 600; margin-bottom: 8px; display: block; color: var(--text); font-size: 0.85rem; }
        
        .input-group-custom { position: relative; }
        .input-group-custom i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 1rem;
            z-index: 1;
        }
        .form-control-custom {
            width: 100%;
            padding: 12px 45px 12px 45px;
            border: 2px solid var(--light-2);
            border-radius: var(--radius-sm);
            font-size: 0.9rem;
            transition: var(--transition);
        }
        .form-control-custom:focus {
            outline: none;
            border-color: var(--blue);
            box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
        }
        .form-control-custom.error {
            border-color: #ef4444;
        }
        
        .password-toggle {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: #94a3b8;
            transition: var(--transition);
            z-index: 2;
        }
        .password-toggle:hover {
            color: var(--blue);
        }
        
        .btn-signin-submit {
            background: var(--grad-blue);
            color: white;
            border: none;
            width: 100%;
            padding: 14px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 1rem;
            transition: var(--transition);
            margin-top: 10px;
        }
        .btn-signin-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(37,99,235,0.3);
        }
        
        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            margin: 25px 0;
        }
        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid var(--light-2);
        }
        .divider span {
            padding: 0 15px;
            color: #94a3b8;
            font-size: 0.8rem;
        }
        
        .btn-google {
            background: white;
            color: #333;
            border: 1px solid var(--light-2);
            width: 100%;
            padding: 12px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.9rem;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            cursor: pointer;
        }
        .btn-google:hover {
            background: #f8f9fa;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        .btn-google:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }
        
        .signup-link { text-align: center; margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--light-2); }
        .signup-link a { color: var(--blue); text-decoration: none; font-weight: 600; }
        .signup-link a:hover { text-decoration: underline; }
        
        .alert {
            padding: 12px 15px;
            border-radius: var(--radius-sm);
            margin-bottom: 20px;
            font-size: 0.85rem;
        }
        .alert-success { background: #d1fae5; color: #065f46; border: 1px solid #a7f3d0; }
        .alert-error { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }
        .alert-info { background: #dbeafe; color: #1e40af; border: 1px solid #bfdbfe; }
        
        .checkbox-group { display: flex; align-items: center; gap: 10px; margin: 20px 0; }
        .checkbox-group input { width: 18px; height: 18px; cursor: pointer; }
        
        body.dark .signin-card {
            background: var(--dark-2);
        }
        body.dark .form-group label {
            color: var(--light);
        }
        body.dark .form-control-custom {
            background: var(--dark-3);
            border-color: rgba(255,255,255,0.1);
            color: white;
        }
        body.dark .btn-google {
            background: var(--dark-3);
            color: white;
            border-color: rgba(255,255,255,0.1);
        }
        
        @media (max-width: 576px) {
            .signin-header { padding: 30px 20px; }
            .signin-body { padding: 30px 20px; }
            .signin-header h1 { font-size: 1.5rem; }
            .back-home { top: 20px; left: 20px; }
            .back-home a { padding: 6px 14px; font-size: 0.8rem; }
        }
    </style>
</head>
<body>

<div class="back-home">
    <a href="/"><i class="fas fa-arrow-left"></i> Back to Home</a>
</div>

<div class="signin-wrapper">
    <div class="signin-card">
        <div class="signin-header">
            <h1>Welcome Back</h1>
            <p>Sign in to your NeurowexTech account</p>
        </div>
        <div class="signin-body">
            <div id="alert-message"></div>
            
            <form id="signinForm">
                <div class="form-group">
                    <label>Email Address</label>
                    <div class="input-group-custom">
                        <i class="fas fa-envelope"></i>
                        <input type="email" class="form-control-custom" id="email" placeholder="hello@neurowextech.com" required>
                    </div>
                </div>
                
                <div class="form-group">
                    <label>Password</label>
                    <div class="input-group-custom">
                        <i class="fas fa-lock"></i>
                        <input type="password" class="form-control-custom" id="password" placeholder="••••••••" required>
                        <span class="password-toggle" id="togglePassword">
                            <i class="fas fa-eye-slash"></i>
                        </span>
                    </div>
                    <div class="forgot-password" style="text-align: right; margin-top: 8px;">
                        <a href="/forgot-password" style="color:#94a3b8; font-size:0.75rem;">Forgot password?</a>
                    </div>
                </div>
                
                <div class="checkbox-group">
                    <input type="checkbox" id="rememberCheckbox">
                    <label for="rememberCheckbox">Remember me</label>
                </div>
                
                <button type="submit" class="btn-signin-submit" id="submitBtn">
                    <i class="fas fa-sign-in-alt me-2"></i> Sign In
                </button>
            </form>
            
            <div class="divider">
                <span>or continue with</span>
            </div>
            
            <button class="btn-google" id="googleSignInBtn">
                <i class="fab fa-google"></i> Sign in with Google
            </button>
            
            <div class="signup-link">
                Don't have an account? <a href="/sign_up">Sign Up</a>
            </div>
        </div>
    </div>
</div>

<script src="https://accounts.google.com/gsi/client" async defer></script>
<script>
    // Get Google Client ID from server-side variable
    const GOOGLE_CLIENT_ID = '{{googleClientId}}';
    
    console.log('Google Client ID from server:', GOOGLE_CLIENT_ID ? '✅ Present' : '❌ Missing');
    
    const signinForm = document.getElementById('signinForm');
    const alertMessage = document.getElementById('alert-message');
    const submitBtn = document.getElementById('submitBtn');
    const togglePassword = document.getElementById('togglePassword');
    const passwordInput = document.getElementById('password');
    const googleSignInBtn = document.getElementById('googleSignInBtn');

    // Password visibility toggle
    togglePassword.addEventListener('click', function() {
        const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
        passwordInput.setAttribute('type', type);
        this.innerHTML = type === 'password' ? '<i class="fas fa-eye-slash"></i>' : '<i class="fas fa-eye"></i>';
    });

    // Remember me
    const rememberedEmail = localStorage.getItem('rememberedEmail');
    if (rememberedEmail) {
        document.getElementById('email').value = rememberedEmail;
        document.getElementById('rememberCheckbox').checked = true;
    }

    function showAlert(message, type) {
        alertMessage.innerHTML = `<div class="alert alert-${type}">${type === 'error' ? '⚠️ ' : type === 'success' ? '✅ ' : 'ℹ️ '}${message}</div>`;
        setTimeout(() => { if (alertMessage.firstChild) alertMessage.firstChild.remove(); }, 5000);
    }

    // Regular sign in
    signinForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const email = document.getElementById('email').value.trim();
        const password = document.getElementById('password').value;
        const rememberMe = document.getElementById('rememberCheckbox').checked;
        
        if (!email || !password) {
            showAlert('Please enter email and password', 'error');
            return;
        }
        
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Signing in...';
        submitBtn.disabled = true;
        
        try {
            const response = await fetch('/api/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, password, rememberMe })
            });
            
            const data = await response.json();
            
            if (data.success) {
                if (rememberMe) localStorage.setItem('rememberedEmail', email);
                else localStorage.removeItem('rememberedEmail');
                
                showAlert(data.message, 'success');
                setTimeout(() => window.location.href = data.redirect, 1000);
            } else {
                showAlert(data.message, 'error');
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
            }
        } catch (err) {
            showAlert('Network error. Please try again.', 'error');
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
        }
    });

    // Google Sign In - Check if client ID is available
    if (GOOGLE_CLIENT_ID && GOOGLE_CLIENT_ID !== '' && GOOGLE_CLIENT_ID !== 'undefined') {
        console.log('Initializing Google Sign-In with ID:', GOOGLE_CLIENT_ID.substring(0, 20) + '...');
        
        // Initialize Google Identity Services
        google.accounts.id.initialize({
            client_id: GOOGLE_CLIENT_ID,
            callback: async (response) => {
                console.log('Google callback received');
                googleSignInBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Signing in...';
                googleSignInBtn.disabled = true;
                
                try {
                    const apiResponse = await fetch('/api/auth/google', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ idToken: response.credential })
                    });
                    
                    const data = await apiResponse.json();
                    
                    if (data.success) {
                        showAlert(data.message, 'success');
                        setTimeout(() => window.location.href = data.redirect, 1000);
                    } else {
                        showAlert(data.message || 'Google sign-in failed', 'error');
                        googleSignInBtn.innerHTML = '<i class="fab fa-google"></i> Sign in with Google';
                        googleSignInBtn.disabled = false;
                    }
                } catch (err) {
                    console.error('Google auth error:', err);
                    showAlert('Network error. Please try again.', 'error');
                    googleSignInBtn.innerHTML = '<i class="fab fa-google"></i> Sign in with Google';
                    googleSignInBtn.disabled = false;
                }
            },
            auto_select: false,
            cancel_on_tap_outside: true,
        });
        
        // Render the Google button
        googleSignInBtn.addEventListener('click', () => {
            console.log('Google button clicked, prompting sign-in...');
            google.accounts.id.prompt();
        });
        
        googleSignInBtn.disabled = false;
    } else {
        console.warn('Google Client ID is missing or invalid');
        googleSignInBtn.disabled = true;
        googleSignInBtn.title = 'Google Sign-In not configured';
        
        // Optional: Show a tooltip or style differently
        googleSignInBtn.style.opacity = '0.6';
        googleSignInBtn.style.cursor = 'not-allowed';
        
        // Add click handler to show error message
        googleSignInBtn.addEventListener('click', () => {
            showAlert('Google Sign-In is not configured. Please contact the administrator.', 'error');
        });
    }
</script>
</body>
</html>