                    <td>${'★'.repeat(t.rating || 5)}</td>
                    <td><span class="pill ${t.published ? 'pill-green' : 'pill-dim'}">${t.published ? 'Live' : 'Draft'}</span></td>
                    <td><button class="act-btn act-del" onclick="deleteTestimonial(${t.id})"><i class="fas fa-trash"></i></button></td>
                </tr>`).join('')
            : `<tr><td colspan="5"><div class="empty-state"><i class="fas fa-star"></i><p>No testimonials yet</p></div></td></tr>`;
    }

    async function createTestimonial() {
        const name = document.getElementById('tClientName').value.trim();
        const content = document.getElementById('tContent').value.trim();
        if (!name || !content) return toast('Client name and content required', 'error');
        const body = {
            client_name: name,
            client_role: document.getElementById('tClientRole').value,
            company:     document.getElementById('tCompany').value,
            rating:      parseInt(document.getElementById('tRating').value),
            content,
        };
        const res = await apiFetch('/api/testimonials', { method: 'POST', body: JSON.stringify(body) });
        if (res?.success) { toast('Testimonial added!'); closeModal('addTestimonialModal'); loadTestimonialsTable(); }
    }

    async function deleteTestimonial(id) {
        if (!confirm('Delete this testimonial?')) return;
        const res = await apiFetch(`/api/testimonials/${id}`, { method: 'DELETE' });
        if (res?.success) { toast('Deleted'); loadTestimonialsTable(); }
    }

    /* ============================================================
       TEAM TABLE
    ============================================================ */
    async function loadTeamTable() {
        const data = await apiFetch('/api/team');
        const members = data?.team || [];
        const tb = document.getElementById('teamTableBody');
        if (!tb) return;
        tb.innerHTML = members.length
            ? members.map(m => `
                <tr>
                    <td class="td-name">${esc(m.name)}</td>
                    <td><span class="pill pill-purple">${esc(m.role)}</span></td>
                    <td>${m.linkedin_url ? `<a href="${esc(m.linkedin_url)}" target="_blank" class="pill pill-blue">↗</a>` : '—'}</td>
                    <td>${m.github_url ? `<a href="${esc(m.github_url)}" target="_blank" class="pill pill-dim">↗</a>` : '—'}</td>
                    <td><button class="act-btn act-del" onclick="deleteTeamMember(${m.id})"><i class="fas fa-trash"></i></button></td>
                </tr>`).join('')
            : `<tr><td colspan="5"><div class="empty-state"><i class="fas fa-id-badge"></i><p>No team members in database</p></div></td></tr>`;
    }

    async function createTeamMember() {
        const name = document.getElementById('tmName').value.trim();
        const role = document.getElementById('tmRole').value.trim();
        if (!name || !role) return toast('Name and role required', 'error');
        const body = {
            name, role,
            bio:          document.getElementById('tmBio').value,
            linkedin_url: document.getElementById('tmLinkedin').value,
            github_url:   document.getElementById('tmGithub').value,
        };
        const res = await apiFetch('/api/team', { method: 'POST', body: JSON.stringify(body) });
        if (res?.success) { toast('Team member added!'); closeModal('addTeamModal'); loadTeamTable(); }
    }

    async function deleteTeamMember(id) {
        if (!confirm('Remove this team member?')) return;
        const res = await apiFetch(`/api/team/${id}`, { method: 'DELETE' });
        if (res?.success) { toast('Removed'); loadTeamTable(); }
    }

    /* ============================================================
       SETTINGS
    ============================================================ */
    async function saveSettings() {
        const body = {
            site_name:        document.getElementById('cfgSiteName').value,
            contact_email:    document.getElementById('cfgEmail').value,
            whatsapp_number:  document.getElementById('cfgWhatsapp').value,
            location:         document.getElementById('cfgLocation').value,
        };
        const res = await apiFetch('/api/settings', { method: 'PUT', body: JSON.stringify(body) });
        if (res?.success) toast('Settings saved!');
    }

    /* ============================================================
       REFRESH BUTTON
    ============================================================ */
    document.getElementById('refreshBtn').addEventListener('click', async () => {
        const btn = document.getElementById('refreshBtn');
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
        await Promise.all([loadDashboard(), updateCharts()]);
        btn.innerHTML = '<i class="fas fa-arrows-rotate"></i>';
        toast('Data refreshed', 'info');
    });

    /* ============================================================
       SCROLL PROGRESS
    ============================================================ */
    document.getElementById('mainContent').addEventListener('scroll', () => {
        const el = document.getElementById('mainContent');
        const pct = (el.scrollTop / (el.scrollHeight - el.clientHeight)) * 100;
        document.getElementById('scroll-progress').style.width = pct + '%';
    }, { passive: true });

    /* ============================================================
       INIT
    ============================================================ */
    window.addEventListener('DOMContentLoaded', () => {
        initCharts();
        loadDashboard();
        updateCharts();

        // Auto-refresh every 30 seconds
        setInterval(() => { loadDashboard(); updateCharts(); }, 30000);
    });
</script>
</body>
</html>