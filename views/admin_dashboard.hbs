<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>

    <!-- Same font stack as home.hbs -->
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

    <style>
        /* ===== VARIABLES — mirror home.hbs palette ===== */
        :root {
            --blue:         #2563eb;
            --blue-dark:    #1d4ed8;
            --blue-light:   #60a5fa;
            --blue-dim:     rgba(37,99,235,0.10);
            --orange:       #f97316;
            --orange-dark:  #ea580c;
            --orange-dim:   rgba(249,115,22,0.10);
            --green:        #10b981;
            --green-dim:    rgba(16,185,129,0.10);
            --red:          #ef4444;
            --red-dim:      rgba(239,68,68,0.10);
            --purple:       #8b5cf6;
            --purple-dim:   rgba(139,92,246,0.10);
            --cyan:         #06b6d4;
            --yellow:       #eab308;

            /* Dark background system (matches home dark sections) */
            --dark:         #050b18;
            --dark-2:       #0d1526;
            --dark-3:       #111827;
            --dark-4:       #1a2236;
            --mid:          #1e293b;
            --border:       rgba(255,255,255,0.06);
            --border-strong: rgba(255,255,255,0.12);

            --text:         #e2e8f0;
            --text-mid:     #94a3b8;
            --text-dim:     #64748b;
            --white:        #ffffff;

            --grad-blue:    linear-gradient(135deg, #2563eb, #1d4ed8);
            --grad-orange:  linear-gradient(135deg, #f97316, #ea580c);
            --grad-dark:    linear-gradient(145deg, #0d1526, #050b18);

            --font-head:    'Syne', sans-serif;
            --font-body:    'Inter', sans-serif;
            --radius:       16px;
            --radius-sm:    10px;
            --radius-lg:    22px;
            --sidebar-w:    264px;
            --sidebar-col:  70px;
            --topbar-h:     64px;
            --t:            all 0.28s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* ===== BASE ===== */
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: var(--font-body);
            background: var(--dark);
            color: var(--text);
            overflow-x: hidden;
            font-size: 14px;
        }
        h1,h2,h3,h4,h5,h6 { font-family: var(--font-head); }

        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-track { background: var(--dark-2); }
        ::-webkit-scrollbar-thumb { background: var(--blue); border-radius: 6px; }

        /* ===== SIDEBAR ===== */
        .sidebar {
            position: fixed; left: 0; top: 0;
            width: var(--sidebar-w); height: 100vh;
            background: var(--dark-2);
            border-right: 1px solid var(--border);
            display: flex; flex-direction: column;
            z-index: 1050; transition: var(--t);
            overflow: hidden;
        }
        .sidebar.collapsed { width: var(--sidebar-col); }

        .sidebar-logo {
            display: flex; align-items: center; gap: 12px;
            padding: 20px 18px; min-height: var(--topbar-h);
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
        }
        .logo-mark {
            width: 36px; height: 36px; min-width: 36px;
            border-radius: 10px;
            background: var(--grad-blue);
            display: flex; align-items: center; justify-content: center;
            font-family: var(--font-head); font-weight: 800;
            font-size: 1rem; color: white; letter-spacing: -0.5px;
        }
        .logo-text { overflow: hidden; white-space: nowrap; transition: var(--t); }
        .logo-text strong {
            display: block; font-family: var(--font-head);
            font-size: 0.95rem; font-weight: 800; color: white;
            letter-spacing: -0.3px; line-height: 1.2;
        }
        .logo-text span { font-size: 0.62rem; color: var(--orange); font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; }
        .sidebar.collapsed .logo-text { opacity: 0; width: 0; }

        .sidebar-nav { flex: 1; overflow-y: auto; overflow-x: hidden; padding: 12px 0; }
        .sidebar-nav::-webkit-scrollbar { width: 0; }

        .nav-section-label {
            padding: 14px 20px 4px;
            font-size: 0.6rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 2px;
            color: var(--text-dim); white-space: nowrap;
            transition: var(--t);
        }
        .sidebar.collapsed .nav-section-label { opacity: 0; }

        .nav-item-wrap { margin: 2px 8px; }
        .nav-link-admin {
            display: flex; align-items: center; gap: 11px;
            padding: 9px 12px; border-radius: var(--radius-sm);
            color: var(--text-mid); text-decoration: none;
            transition: var(--t); cursor: pointer;
            border: 1px solid transparent; white-space: nowrap;
            position: relative;
        }
        .nav-link-admin:hover {
            background: rgba(255,255,255,0.04);
            border-color: var(--border);
            color: var(--text);
        }
        .nav-item-wrap.active .nav-link-admin {
            background: var(--blue-dim);
            border-color: rgba(37,99,235,0.2);
            color: var(--blue-light);
        }
        .nav-icon-wrap {
            width: 20px; min-width: 20px; font-size: 0.88rem;
            text-align: center; flex-shrink: 0;
        }
        .nav-item-wrap.active .nav-icon-wrap { color: var(--blue-light); }
        .nav-lbl { font-size: 0.84rem; font-weight: 500; transition: var(--t); }
        .sidebar.collapsed .nav-lbl { opacity: 0; width: 0; overflow: hidden; }
        .nav-badge-count {
            margin-left: auto; background: var(--red);
            color: white; font-size: 0.6rem; font-weight: 700;
            padding: 2px 6px; border-radius: 99px; min-width: 18px;
            text-align: center; transition: var(--t);
        }
        .sidebar.collapsed .nav-badge-count { opacity: 0; }

        .sidebar-footer {
            border-top: 1px solid var(--border);
            padding: 10px 8px; flex-shrink: 0;
        }

        /* Tooltip on collapsed */
        .sidebar.collapsed .nav-link-admin::after {
            content: attr(data-label);
            position: absolute; left: calc(var(--sidebar-col) - 4px);
            background: var(--dark-4); color: var(--text);
            font-size: 0.78rem; font-weight: 500;
            padding: 6px 12px; border-radius: var(--radius-sm);
            border: 1px solid var(--border-strong);
            white-space: nowrap; pointer-events: none;
            opacity: 0; transform: translateX(-4px);
            transition: opacity 0.2s, transform 0.2s;
            z-index: 200;
        }
        .sidebar.collapsed .nav-link-admin:hover::after {
            opacity: 1; transform: translateX(0);
        }

        /* ===== TOPBAR ===== */
        .topbar {
            position: fixed; top: 0;
            left: var(--sidebar-w); right: 0;
            height: var(--topbar-h);
            background: var(--dark-2);
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center;
            justify-content: space-between;
            padding: 0 24px; z-index: 1000;
            transition: left var(--t);
        }
        .topbar.collapsed { left: var(--sidebar-col); }

        .topbar-left { display: flex; align-items: center; gap: 14px; }
        .toggle-sidebar-btn {
            width: 36px; height: 36px; border-radius: 10px;
            background: rgba(255,255,255,0.04);
            border: 1px solid var(--border);
            color: var(--text-mid); cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            transition: var(--t); font-size: 0.9rem;
        }
        .toggle-sidebar-btn:hover { background: var(--blue-dim); color: var(--blue-light); border-color: rgba(37,99,235,0.2); }

        .breadcrumb-stack .page-title {
            font-family: var(--font-head); font-size: 1rem;
            font-weight: 700; color: white; line-height: 1;
        }
        .breadcrumb-stack .page-sub { font-size: 0.72rem; color: var(--text-dim); margin-top: 2px; }

        .topbar-right { display: flex; align-items: center; gap: 10px; }
        .topbar-action {
            width: 36px; height: 36px; border-radius: 10px;
            background: rgba(255,255,255,0.04);
            border: 1px solid var(--border);
            color: var(--text-mid); cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            transition: var(--t); text-decoration: none; font-size: 0.9rem;
        }
        .topbar-action:hover { border-color: var(--border-strong); color: var(--text); }
        .topbar-action.wa:hover { background: rgba(37,211,102,0.1); color: #25D366; border-color: rgba(37,211,102,0.2); }
        .topbar-action.refresh:hover { background: var(--blue-dim); color: var(--blue-light); }

        .user-chip {
            display: flex; align-items: center; gap: 9px;
            background: rgba(255,255,255,0.04);
            border: 1px solid var(--border);
            border-radius: 50px; padding: 5px 14px 5px 5px;
            cursor: pointer; transition: var(--t);
        }
        .user-chip:hover { border-color: var(--border-strong); }
        .user-avatar {
            width: 28px; height: 28px; border-radius: 50%;
            background: var(--grad-blue);
            display: flex; align-items: center; justify-content: center;
            font-family: var(--font-head); font-weight: 700;
            font-size: 0.75rem; color: white;
        }
        .user-chip span { font-size: 0.8rem; font-weight: 500; color: var(--text); }

        /* ===== MAIN AREA ===== */
        .main-content {
            margin-left: var(--sidebar-w);
            padding-top: var(--topbar-h);
            min-height: 100vh;
            transition: margin-left var(--t);
        }
        .main-content.collapsed { margin-left: var(--sidebar-col); }

        /* ===== PAGES ===== */
        .admin-page { padding: 28px; display: none; animation: fadeIn 0.3s ease; }
        .admin-page.active { display: block; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }

        .page-header {
            display: flex; align-items: flex-start;
            justify-content: space-between; margin-bottom: 28px;
            gap: 16px; flex-wrap: wrap;
        }
        .page-header h2 {
            font-family: var(--font-head); font-size: 1.6rem;
            font-weight: 800; color: white; line-height: 1.1;
        }
        .page-header .sub { color: var(--text-dim); font-size: 0.83rem; margin-top: 4px; }

        /* ===== STAT CARDS ===== */
        .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
        @media (max-width:1100px) { .stats-row { grid-template-columns: repeat(2,1fr); } }
        @media (max-width:580px)  { .stats-row { grid-template-columns: 1fr; } }

        .stat-card {
            background: var(--dark-2);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 22px 20px; position: relative;
            overflow: hidden; transition: var(--t);
        }
        .stat-card::before {
            content: ''; position: absolute;
            top: 0; left: 0; right: 0; height: 2px;
            border-radius: var(--radius) var(--radius) 0 0;
        }
        .stat-card.c-blue::before   { background: linear-gradient(90deg, var(--blue), var(--blue-light)); }
        .stat-card.c-orange::before { background: linear-gradient(90deg, var(--orange), #fb923c); }
        .stat-card.c-green::before  { background: linear-gradient(90deg, var(--green), #34d399); }
        .stat-card.c-purple::before { background: linear-gradient(90deg, var(--purple), #c084fc); }

        .stat-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(0,0,0,0.3); }

        .stat-icon-wrap {
            width: 42px; height: 42px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; margin-bottom: 14px;
        }
        .c-blue  .stat-icon-wrap { background: var(--blue-dim);   color: var(--blue-light); }
        .c-orange .stat-icon-wrap { background: var(--orange-dim); color: var(--orange); }
        .c-green  .stat-icon-wrap { background: var(--green-dim);  color: var(--green); }
        .c-purple .stat-icon-wrap { background: var(--purple-dim); color: var(--purple); }

        .stat-val {
            font-family: var(--font-head);
            font-size: 2.2rem; font-weight: 800;
            color: white; line-height: 1; margin-bottom: 4px;
        }
        .stat-lbl { font-size: 0.76rem; color: var(--text-dim); font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px; }
        .stat-trend {
            position: absolute; top: 20px; right: 18px;
            font-size: 0.72rem; font-weight: 600;
            padding: 3px 8px; border-radius: 99px;
        }
        .trend-up   { background: var(--green-dim);  color: var(--green); }
        .trend-new  { background: var(--blue-dim);   color: var(--blue-light); }

        /* ===== CARDS ===== */
        .panel {
            background: var(--dark-2);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden; transition: var(--t);
        }
        .panel-header {
            padding: 18px 22px;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center;
            justify-content: space-between; gap: 12px;
            flex-wrap: wrap;
        }
        .panel-title {
            font-family: var(--font-head);
            font-size: 0.95rem; font-weight: 700;
            color: white; display: flex; align-items: center; gap: 8px;
        }
        .panel-title i { color: var(--blue-light); font-size: 0.9rem; }
        .panel-body { padding: 20px 22px; }

        /* ===== CHARTS GRID ===== */
        .charts-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 16px; margin-bottom: 24px; }
        @media (max-width:900px) { .charts-grid { grid-template-columns: 1fr; } }

        .chart-wrap { position: relative; }

        /* ===== DATA TABLE ===== */
        .data-tbl { width: 100%; border-collapse: collapse; }
        .data-tbl thead th {
            padding: 10px 16px;
            font-size: 0.67rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 1px;
            color: var(--text-dim);
            background: rgba(255,255,255,0.02);
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }
        .data-tbl tbody td {
            padding: 13px 16px;
            font-size: 0.82rem; color: var(--text-mid);
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
        }
        .data-tbl tbody tr:last-child td { border-bottom: none; }
        .data-tbl tbody tr:hover td { background: rgba(255,255,255,0.02); }
        .td-name { color: white; font-weight: 600; }

        /* ===== BADGES ===== */
        .pill {
            display: inline-flex; align-items: center; gap: 4px;
            padding: 3px 10px; border-radius: 99px;
            font-size: 0.67rem; font-weight: 700; white-space: nowrap;
        }
        .pill-blue   { background: var(--blue-dim);   color: var(--blue-light); }
        .pill-orange { background: var(--orange-dim); color: var(--orange); }
        .pill-green  { background: var(--green-dim);  color: var(--green); }
        .pill-purple { background: var(--purple-dim); color: var(--purple); }
        .pill-red    { background: var(--red-dim);    color: var(--red); }
        .pill-dim    { background: rgba(255,255,255,0.06); color: var(--text-dim); }

        /* ===== ACTION BUTTONS ===== */
        .act-btn {
            width: 30px; height: 30px; border-radius: 8px; border: none;
            display: inline-flex; align-items: center; justify-content: center;
            cursor: pointer; font-size: 0.75rem; transition: var(--t); margin: 0 2px;
        }
        .act-edit   { background: var(--blue-dim);   color: var(--blue-light); }
        .act-edit:hover { background: var(--blue); color: white; }
        .act-del    { background: var(--red-dim);    color: var(--red); }
        .act-del:hover { background: var(--red); color: white; }
        .act-view   { background: var(--green-dim);  color: var(--green); }
        .act-view:hover { background: var(--green); color: white; }
        .act-shield { background: var(--purple-dim); color: var(--purple); }
        .act-shield:hover { background: var(--purple); color: white; }

        /* ===== BUTTONS ===== */
        .btn-admin-primary {
            display: inline-flex; align-items: center; gap: 7px;
            background: var(--grad-blue); color: white;
            border: none; padding: 9px 18px; border-radius: 50px;
            font-family: var(--font-head); font-weight: 600;
            font-size: 0.8rem; cursor: pointer; transition: var(--t);
            white-space: nowrap; text-decoration: none;
        }
        .btn-admin-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 22px rgba(37,99,235,0.35); color: white; }

        .btn-admin-ghost {
            display: inline-flex; align-items: center; gap: 7px;
            background: rgba(255,255,255,0.04); color: var(--text-mid);
            border: 1px solid var(--border); padding: 8px 14px; border-radius: 50px;
            font-family: var(--font-head); font-weight: 600;
            font-size: 0.78rem; cursor: pointer; transition: var(--t);
            white-space: nowrap; text-decoration: none;
        }
        .btn-admin-ghost:hover { border-color: var(--border-strong); color: var(--text); }

        .btn-admin-orange {
            display: inline-flex; align-items: center; gap: 7px;
            background: var(--grad-orange); color: white;
            border: none; padding: 9px 18px; border-radius: 50px;
            font-family: var(--font-head); font-weight: 600;
            font-size: 0.8rem; cursor: pointer; transition: var(--t);
        }
        .btn-admin-orange:hover { transform: translateY(-2px); box-shadow: 0 8px 22px rgba(249,115,22,0.35); }

        /* ===== SEARCH BOX ===== */
        .search-wrap {
            display: flex; align-items: center; gap: 8px;
            background: rgba(255,255,255,0.04);
            border: 1px solid var(--border); border-radius: 50px;
            padding: 7px 14px;
        }
        .search-wrap i { color: var(--text-dim); font-size: 0.82rem; }
        .search-wrap input {
            background: none; border: none; outline: none;
            color: var(--text); font-family: var(--font-body);
            font-size: 0.82rem; width: 180px;
        }
        .search-wrap input::placeholder { color: var(--text-dim); }

        /* ===== WA BANNER ===== */
        .wa-banner {
            background: linear-gradient(135deg, rgba(37,211,102,0.07), rgba(18,140,126,0.07));
            border: 1px solid rgba(37,211,102,0.18);
            border-radius: var(--radius); padding: 14px 20px;
            display: flex; align-items: center;
            justify-content: space-between; gap: 12px;
            margin-bottom: 24px; flex-wrap: wrap;
        }
        .wa-banner-left { display: flex; align-items: center; gap: 10px; font-size: 0.84rem; color: #6ee7b7; font-weight: 500; }
        .wa-dot { width: 8px; height: 8px; border-radius: 50%; background: #25D366; animation: waPulse 2s infinite; }
        @keyframes waPulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.6;transform:scale(1.3)} }

        /* ===== QUICK ACTIONS ===== */
        .quick-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
        .quick-btn {
            display: flex; align-items: center; gap: 10px;
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm); padding: 12px;
            cursor: pointer; transition: var(--t); text-align: left;
        }
        .quick-btn:hover { border-color: var(--blue); background: var(--blue-dim); transform: translateY(-2px); }
        .quick-btn .qb-icon {
            width: 32px; height: 32px; border-radius: 8px;
            background: var(--blue-dim); color: var(--blue-light);
            display: flex; align-items: center; justify-content: center;
            font-size: 0.85rem; flex-shrink: 0;
        }
        .quick-btn span { font-size: 0.78rem; font-weight: 600; color: var(--text); }

        /* ===== ACTIVITY ===== */
        .activity-item {
            display: flex; align-items: flex-start; gap: 12px;
            padding: 12px 0;
            border-bottom: 1px solid var(--border);
        }
        .activity-item:last-child { border-bottom: none; }
        .act-dot {
            width: 32px; height: 32px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 0.8rem; flex-shrink: 0; margin-top: 2px;
        }
        .act-dot.msg { background: var(--blue-dim); color: var(--blue-light); }
        .act-dot.user { background: var(--green-dim); color: var(--green); }
        .act-dot.sub { background: var(--purple-dim); color: var(--purple); }
        .activity-item p { font-size: 0.8rem; color: var(--text); margin: 0; }
        .activity-item time { font-size: 0.7rem; color: var(--text-dim); }

        /* ===== TOAST ===== */
        #toast-container {
            position: fixed; bottom: 24px; right: 24px;
            z-index: 9999; display: flex; flex-direction: column; gap: 10px;
        }
        .toast-item {
            background: var(--dark-4); border: 1px solid var(--border-strong);
            border-radius: var(--radius-sm); padding: 12px 18px;
            color: var(--text); font-size: 0.82rem; font-weight: 500;
            display: flex; align-items: center; gap: 9px;
            animation: toastIn 0.3s ease;
            min-width: 240px; max-width: 320px;
        }
        .toast-item.success { border-left: 3px solid var(--green); }
        .toast-item.error   { border-left: 3px solid var(--red); }
        .toast-item.info    { border-left: 3px solid var(--blue-light); }
        @keyframes toastIn { from { transform: translateX(20px); opacity: 0; } to { transform: none; opacity: 1; } }

        /* ===== MODAL ===== */
        .modal-content {
            background: var(--dark-3) !important;
            border: 1px solid var(--border-strong) !important;
            border-radius: var(--radius-lg) !important;
            color: var(--text) !important;
        }
        .modal-header {
            border-bottom: 1px solid var(--border) !important;
            padding: 18px 22px !important;
        }
        .modal-header .modal-title {
            font-family: var(--font-head); font-weight: 700;
            color: white; font-size: 1rem;
        }
        .modal-footer { border-top: 1px solid var(--border) !important; }
        .btn-close { filter: invert(1) !important; }

        .form-ctrl {
            background: rgba(255,255,255,0.05) !important;
            border: 1px solid var(--border) !important;
            border-radius: var(--radius-sm) !important;
            color: var(--text) !important;
            padding: 10px 14px; width: 100%;
            font-family: var(--font-body); font-size: 0.84rem;
            transition: var(--t);
        }
        .form-ctrl:focus {
            outline: none !important;
            border-color: var(--blue) !important;
            box-shadow: 0 0 0 3px rgba(37,99,235,0.15) !important;
            background: rgba(255,255,255,0.07) !important;
        }
        .form-ctrl::placeholder { color: var(--text-dim) !important; }
        .form-ctrl option { background: var(--dark-3); }
        label.ctrl-label {
            font-size: 0.76rem; font-weight: 600;
            color: var(--text-mid); margin-bottom: 5px; display: block;
        }

        /* ===== USER PROFILE BOX ===== */
        .user-profile-box {
            display: flex; align-items: center; gap: 16px;
            padding: 20px 22px;
            background: var(--dark-4); border-bottom: 1px solid var(--border);
        }
        .user-avatar-lg {
            width: 50px; height: 50px; border-radius: 50%;
            background: var(--grad-blue);
            display: flex; align-items: center; justify-content: center;
            font-family: var(--font-head); font-weight: 800;
            font-size: 1.2rem; color: white; flex-shrink: 0;
        }
        .user-profile-box .uname { font-family: var(--font-head); font-weight: 700; color: white; }
        .user-profile-box .urole { font-size: 0.72rem; color: var(--orange); font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }

        /* ===== SETTINGS ===== */
        .setting-section { margin-bottom: 24px; }
        .setting-section-title {
            font-family: var(--font-head); font-weight: 700;
            color: var(--text-mid); font-size: 0.72rem;
            text-transform: uppercase; letter-spacing: 1.5px;
            margin-bottom: 14px; padding-bottom: 10px;
            border-bottom: 1px solid var(--border);
        }
        .setting-row {
            display: flex; align-items: center;
            justify-content: space-between; gap: 16px;
            padding: 12px 0; border-bottom: 1px solid var(--border);
            flex-wrap: wrap;
        }
        .setting-row:last-child { border-bottom: none; }
        .setting-row-info p { font-size: 0.84rem; font-weight: 600; color: var(--text); margin: 0; }
        .setting-row-info span { font-size: 0.76rem; color: var(--text-dim); }

        /* toggle switch */
        .toggle-switch { position: relative; display: inline-block; width: 40px; height: 22px; flex-shrink: 0; }
        .toggle-switch input { display: none; }
        .toggle-track {
            position: absolute; inset: 0; border-radius: 99px;
            background: var(--border-strong); cursor: pointer; transition: var(--t);
        }
        .toggle-track::after {
            content: ''; position: absolute;
            top: 3px; left: 3px;
            width: 16px; height: 16px; border-radius: 50%;
            background: white; transition: var(--t);
        }
        .toggle-switch input:checked + .toggle-track { background: var(--blue); }
        .toggle-switch input:checked + .toggle-track::after { transform: translateX(18px); }

        /* ===== SECTION TAG (matches home.hbs) ===== */
        .section-tag {
            display: inline-block; background: rgba(37,99,235,0.12);
            color: var(--blue-light); border-radius: 50px;
            padding: 4px 14px; font-size: 0.67rem;
            font-weight: 700; letter-spacing: 1.5px;
            text-transform: uppercase; margin-bottom: 6px;
        }

        /* ===== GRID HELPERS ===== */
        .two-col { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; }
        @media (max-width:1024px) { .two-col { grid-template-columns: 1fr; } }
        .three-col { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
        @media (max-width:900px)  { .three-col { grid-template-columns: 1fr 1fr; } }
        @media (max-width:580px)  { .three-col { grid-template-columns: 1fr; } }

        /* ===== MOBILE OVERLAY ===== */
        .sidebar-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,0.6); z-index: 1040;
            backdrop-filter: blur(4px);
        }
        @media (max-width:991px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.mobile-open { transform: translateX(0); }
            .topbar, .main-content { left: 0 !important; margin-left: 0 !important; }
            .sidebar-overlay { display: block; }
        }

        /* ===== SCROLL PROGRESS ===== */
        #scroll-progress {
            position: fixed; top: 0; left: 0; height: 2px; width: 0%;
            background: linear-gradient(90deg, var(--blue), var(--orange));
            z-index: 9999; pointer-events: none;
        }

        /* ===== EMPTY STATE ===== */
        .empty-state { padding: 36px; text-align: center; }
        .empty-state i { font-size: 2.5rem; color: var(--text-dim); margin-bottom: 10px; }
        .empty-state p { color: var(--text-dim); font-size: 0.85rem; }

        /* ===== GRADIENT TEXT (matches home) ===== */
        .g-text-blue   { background: var(--grad-blue);   -webkit-background-clip: text; background-clip: text; color: transparent; }
        .g-text-orange { background: var(--grad-orange); -webkit-background-clip: text; background-clip: text; color: transparent; }

        /* Mobile responsive tweaks */
        @media (max-width:580px) {
            .admin-page { padding: 16px; }
            .page-header h2 { font-size: 1.3rem; }
            .stat-val { font-size: 1.8rem; }
        }
    </style>
</head>
