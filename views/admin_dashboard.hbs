<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>NeurowexTech — Admin Command Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg: #06080f;
            --bg-2: #0c1018;
            --bg-3: #111620;
            --bg-4: #181e2d;
            --border: rgba(255,255,255,0.07);
            --border-strong: rgba(255,255,255,0.12);
            --blue: #3b82f6;
            --blue-dim: rgba(59,130,246,0.12);
            --blue-bright: #60a5fa;
            --orange: #f97316;
            --orange-dim: rgba(249,115,22,0.12);
            --green: #22c55e;
            --green-dim: rgba(34,197,94,0.12);
            --red: #ef4444;
            --red-dim: rgba(239,68,68,0.12);
            --yellow: #eab308;
            --yellow-dim: rgba(234,179,8,0.12);
            --purple: #a855f7;
            --purple-dim: rgba(168,85,247,0.12);
            --cyan: #06b6d4;
            --cyan-dim: rgba(6,182,212,0.12);
            --text: #e2e8f0;
            --text-dim: #64748b;
            --text-mid: #94a3b8;
            --white: #ffffff;
            --sidebar-w: 260px;
            --sidebar-collapsed: 72px;
            --font: 'Outfit', sans-serif;
            --mono: 'JetBrains Mono', monospace;
            --radius: 14px;
            --radius-sm: 8px;
            --radius-lg: 20px;
            --t: all 0.25s cubic-bezier(0.4,0,0.2,1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: var(--font);
            background: var(--bg);
            color: var(--text);
            overflow-x: hidden;
            font-size: 14px;
        }

        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 99px; }

        /* Sidebar & Layout (same refined styles as original) */
        .sidebar { position: fixed; left: 0; top: 0; height: 100vh; width: var(--sidebar-w); background: var(--bg-2); border-right: 1px solid var(--border); display: flex; flex-direction: column; z-index: 1000; transition: var(--t); overflow: hidden; }
        .sidebar.collapsed { width: var(--sidebar-collapsed); }
        .sidebar-logo { padding: 24px 20px 20px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 12px; min-height: 72px; }
        .logo-icon { width: 38px; height: 38px; min-width: 38px; background: linear-gradient(135deg, #3b82f6, #1d4ed8); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-weight: 800; color: white; }
        .logo-text strong { display: block; font-size: 1rem; font-weight: 800; color: var(--white); letter-spacing: -0.3px; }
        .logo-text span { font-size: 0.7rem; color: var(--orange); font-weight: 600; text-transform: uppercase; }
        .sidebar-section-label { padding: 16px 20px 6px; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 2px; color: var(--text-dim); font-weight: 600; transition: var(--t); }
        .sidebar.collapsed .sidebar-section-label { opacity: 0; }
        .nav-item { margin: 2px 10px; border-radius: var(--radius-sm); transition: var(--t); }
        .nav-link-item { display: flex; align-items: center; gap: 12px; padding: 10px 12px; color: var(--text-mid); text-decoration: none; border-radius: var(--radius-sm); transition: var(--t); cursor: pointer; white-space: nowrap; border: 1px solid transparent; }
        .nav-link-item:hover { background: var(--bg-4); color: var(--text); border-color: var(--border); }
        .nav-item.active .nav-link-item { background: var(--blue-dim); color: var(--blue-bright); border-color: rgba(59,130,246,0.2); }
        .nav-icon { width: 18px; min-width: 18px; font-size: 0.95rem; text-align: center; }
        .nav-label { font-size: 0.88rem; font-weight: 500; }
        .sidebar.collapsed .nav-label { opacity: 0; width: 0; }
        .nav-badge { margin-left: auto; background: var(--red); color: white; font-size: 0.62rem; font-weight: 700; padding: 2px 6px; border-radius: 99px; min-width: 18px; text-align: center; }
        .sidebar.collapsed .nav-badge { opacity: 0; }
        .topbar { position: fixed; top: 0; left: var(--sidebar-w); right: 0; height: 64px; background: var(--bg-2); border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; padding: 0 28px; z-index: 900; transition: left var(--t); }
        .topbar.expanded { left: var(--sidebar-collapsed); }
        .main { margin-left: var(--sidebar-w); padding-top: 64px; min-height: 100vh; transition: margin-left var(--t); }
        .main.expanded { margin-left: var(--sidebar-collapsed); }
        .page-content { padding: 28px; display: none; }
        .page-content.active { display: block; }
        .card-base { background: var(--bg-3); border: 1px solid var(--border); border-radius: var(--radius); transition: var(--t); }
        .stat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
        @media(max-width:1200px) { .stat-grid { grid-template-columns: repeat(2, 1fr); } }
        @media(max-width:600px) { .stat-grid { grid-template-columns: 1fr; } }
        .stat-card { background: var(--bg-3); border: 1px solid var(--border); border-radius: var(--radius); padding: 22px; transition: var(--t); position: relative; overflow: hidden; }
        .stat-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; border-radius: var(--radius) var(--radius) 0 0; }
        .stat-card.blue::before { background: linear-gradient(90deg, var(--blue), #60a5fa); }
        .stat-card.green::before { background: linear-gradient(90deg, var(--green), #4ade80); }
        .stat-card.orange::before { background: linear-gradient(90deg, var(--orange), #fb923c); }
        .stat-card.purple::before { background: linear-gradient(90deg, var(--purple), #c084fc); }
        .stat-value { font-size: 2rem; font-weight: 800; color: var(--white); line-height: 1; }
        .stat-label { font-size: 0.78rem; color: var(--text-dim); font-weight: 500; }
        .btn-primary-dark { display: inline-flex; align-items: center; gap: 7px; background: var(--blue); color: white; border: none; padding: 8px 16px; border-radius: var(--radius-sm); font-weight: 600; cursor: pointer; transition: var(--t); white-space: nowrap; }
        .btn-primary-dark:hover { background: var(--blue-bright); transform: translateY(-1px); }
        .btn-ghost-dark { display: inline-flex; align-items: center; gap: 7px; background: var(--bg-4); color: var(--text-mid); border: 1px solid var(--border); padding: 8px 14px; border-radius: var(--radius-sm); font-weight: 500; cursor: pointer; transition: var(--t); white-space: nowrap; }
        .btn-ghost-dark:hover { border-color: var(--border-strong); color: var(--text); }
        .table-card { background: var(--bg-3); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; margin-bottom: 20px; }
        .table-card-header { padding: 18px 22px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
        .data-table { width: 100%; border-collapse: collapse; }
        .data-table th { padding: 10px 16px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; color: var(--text-dim); border-bottom: 1px solid var(--border); background: var(--bg-4); white-space: nowrap; }
        .data-table td { padding: 13px 16px; font-size: 0.82rem; color: var(--text-mid); border-bottom: 1px solid var(--border); vertical-align: middle; }
        .data-table tbody tr:hover { background: rgba(255,255,255,0.02); }
        .badge-pill { display: inline-flex; align-items: center; gap: 5px; padding: 3px 10px; border-radius: 99px; font-size: 0.68rem; font-weight: 700; white-space: nowrap; }
        .bp-green { background: var(--green-dim); color: var(--green); }
        .bp-blue { background: var(--blue-dim); color: var(--blue-bright); }
        .bp-orange { background: var(--orange-dim); color: var(--orange); }
        .bp-purple { background: var(--purple-dim); color: var(--purple); }
        .bp-yellow { background: var(--yellow-dim); color: var(--yellow); }
        .act-btn { width: 30px; height: 30px; border-radius: 6px; border: none; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; font-size: 0.78rem; transition: var(--t); margin: 0 2px; }
        .act-edit { background: var(--blue-dim); color: var(--blue-bright); }
        .act-delete { background: var(--red-dim); color: var(--red); }
        .act-view { background: var(--green-dim); color: var(--green); }
        .charts-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 16px; margin-bottom: 24px; }
        .chart-card { background: var(--bg-3); border: 1px solid var(--border); border-radius: var(--radius); padding: 22px; }
        .search-box { display: flex; align-items: center; gap: 8px; background: var(--bg-4); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 7px 12px; min-width: 200px; }
        .search-box input { background: none; border: none; outline: none; color: var(--text); font-family: var(--font); font-size: 0.82rem; width: 100%; }
        .wa-banner { background: linear-gradient(135deg, rgba(37,211,102,0.08), rgba(18,140,126,0.08)); border: 1px solid rgba(37,211,102,0.2); border-radius: var(--radius); padding: 16px 20px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
        .quick-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
        .quick-btn { display: flex; align-items: center; gap: 10px; background: var(--bg-4); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 13px; cursor: pointer; transition: var(--t); }
        .quick-btn:hover { border-color: var(--border-strong); background: var(--bg-3); transform: translateY(-2px); }
        .activity-item { display: flex; align-items: flex-start; gap: 12px; padding: 14px 0; border-bottom: 1px solid var(--border); }
        .toast-container { position: fixed; bottom: 24px; right: 24px; z-index: 9999; display: flex; flex-direction: column; gap: 10px; }
        .toast-item { background: var(--bg-3); border: 1px solid var(--border-strong); border-radius: var(--radius-sm); padding: 12px 18px; color: var(--text); font-size: 0.82rem; font-weight: 500; animation: toastIn 0.3s ease forwards; }
        .toast-item.success { border-left: 3px solid var(--green); }
        @keyframes toastIn { from { transform: translateX(20px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
        @media(max-width:768px) { .sidebar { transform: translateX(-100%); } .sidebar.mobile-open { transform: translateX(0); } .main, .topbar { margin-left: 0 !important; left: 0 !important; } }
        .form-control-dark { background: var(--bg-4); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text); padding: 10px 14px; width: 100%; font-family: var(--font); }
        .modal-dark .modal-content { background: var(--bg-3); border: 1px solid var(--border-strong); border-radius: var(--radius-lg); }
    </style>
</head>
<body>

