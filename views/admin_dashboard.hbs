    async function updateCharts() {
        const [usersData, subsData] = await Promise.all([
            apiFetch('/api/admin/users'),
            apiFetch('/api/subscribers')
        ]);
        const u = usersData?.users?.length || 0;
        const s = subsData?.subscribers?.length || 0;
        if (growthChart) {
            growthChart.data.datasets[0].data = [Math.max(0,u-14),Math.max(0,u-10),Math.max(0,u-7),Math.max(0,u-4),Math.max(0,u-1),u];
            growthChart.data.datasets[1].data = [Math.max(0,s-40),Math.max(0,s-28),Math.max(0,s-16),Math.max(0,s-9),Math.max(0,s-3),s];
            growthChart.update();
        }
    }

    /* ============================================================
       DASHBOARD DATA
    ============================================================ */
    async function loadDashboard() {
        const [usersD, projD, contactsD, subsD] = await Promise.all([
            apiFetch('/api/admin/users'),
            apiFetch('/api/projects'),
            apiFetch('/api/contacts'),
            apiFetch('/api/subscribers')
        ]);

        const u = usersD?.users?.length || 0;
        const p = projD?.projects?.length || 0;
        const c = contactsD?.contacts?.length || 0;
        const s = subsD?.subscribers?.length || 0;

        // Stat cards
        setEl('sUsers', u);
        setEl('sProjects', p);
        setEl('sContacts', c);
        setEl('sSubscribers', s);

        // Sidebar badges
        setEl('sidebarUserCount', u);
        setEl('sidebarContactCount', c);

        // Settings page counters
        setEl('cfgUserCount', u);
        setEl('cfgProjectCount', p);

        // Analytics page
        setEl('aUsers', u);

        // Recent contacts in dashboard
        const recent = (contactsD?.contacts || []).slice(0, 5);
        const dashBody = document.getElementById('dashContactsBody');
        if (dashBody) {
            dashBody.innerHTML = recent.length
                ? recent.map(c => `
                    <tr>
                        <td class="td-name">${esc(c.name)}</td>
                        <td><span class="pill pill-blue">${esc(c.project_type || 'General')}</span></td>
                        <td>${fmtShort(c.created_at)}</td>
                        <td><span class="pill pill-orange">New</span></td>
                    </tr>`).join('')
                : `<tr><td colspan="4"><div class="empty-state"><i class="fas fa-inbox"></i><p>No messages yet</p></div></td></tr>`;
        }

        // Activity feed
        const feed = document.getElementById('activityFeed');
        if (feed) {
            const acts = [];
            (contactsD?.contacts || []).slice(0,3).forEach(c => acts.push({ type:'msg',  label: `New message from <strong>${esc(c.name)}</strong>`, date: c.created_at }));
            (usersD?.users || []).slice(0,2).forEach(u => acts.push({ type:'user', label: `New user registered: <strong>${esc(u.username)}</strong>`, date: u.created_at }));
            (subsD?.subscribers || []).slice(0,2).forEach(s => acts.push({ type:'sub',  label: `Newsletter signup: ${esc(s.email)}`, date: s.subscribed_at }));
            acts.sort((a,b) => new Date(b.date) - new Date(a.date));

            const icons = { msg: 'msg', user: 'user', sub: 'sub' };
            const faIcons = { msg: 'fa-envelope', user: 'fa-user-plus', sub: 'fa-at' };
            feed.innerHTML = acts.slice(0,6).map(a => `
                <div class="activity-item">
                    <div class="act-dot ${icons[a.type]}"><i class="fas ${faIcons[a.type]}"></i></div>
                    <div>
                        <p>${a.label}</p>
                        <time>${fmt(a.date)}</time>
                    </div>
                </div>`).join('') || '<div class="empty-state"><i class="fas fa-clock-rotate-left"></i><p>No recent activity</p></div>';
        }
    }

    function setEl(id, val) {
        const el = document.getElementById(id);
        if (el) el.textContent = val;
    }
    function esc(str) {
        if (!str) return '';
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

