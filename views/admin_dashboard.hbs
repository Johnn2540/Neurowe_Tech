       PAGE NAVIGATION
    ============================================================ */
    const PAGES = ['dashboard','analytics','users','projects','contacts','subscribers','blog','services','portfolio','testimonials','team','settings'];
    const PAGE_TITLES = {
        dashboard:    ['Dashboard',   'Live platform data'],
        analytics:    ['Analytics',   'Traffic & growth insights'],
        users:        ['Users',       'Manage accounts and roles'],
        projects:     ['Projects',    'Showcase portfolio items'],
        contacts:     ['Contacts',    'Leads and enquiries'],
        subscribers:  ['Subscribers', 'Newsletter list'],
        blog:         ['Blog',        'Content management'],
        services:     ['Services',    'Manage offerings'],
        portfolio:    ['Portfolio',   'Portfolio items'],
        testimonials: ['Testimonials','Client reviews'],
        team:         ['Team',        'Manage team profiles'],
        settings:     ['Settings',    'Platform configuration'],
    };

    function switchPage(page) {
        PAGES.forEach(p => {
            document.getElementById(p + 'Page').classList.remove('active');
            const navEl = document.querySelector(`.nav-item-wrap[data-page="${p}"]`);
            if (navEl) navEl.classList.remove('active');
        });
        document.getElementById(page + 'Page').classList.add('active');
        const activeNav = document.querySelector(`.nav-item-wrap[data-page="${page}"]`);
        if (activeNav) activeNav.classList.add('active');

        const [title, sub] = PAGE_TITLES[page] || [page, ''];
        document.getElementById('topbarTitle').textContent = title;
        document.getElementById('topbarSub').textContent = sub;

        // Lazy-load page data
        const loaders = {
            users:        loadUsersTable,
            projects:     loadProjectsTable,
            portfolio:    loadPortfolioTable,
            contacts:     loadContactsTable,
            subscribers:  loadSubscribersTable,
            blog:         loadBlogTable,
            services:     loadServicesTable,
            testimonials: loadTestimonialsTable,
            team:         loadTeamTable,
        };
        if (loaders[page]) loaders[page]();

        // close mobile sidebar
        closeMobileSidebar();
    }

    document.querySelectorAll('.nav-item-wrap[data-page]').forEach(el => {
        el.addEventListener('click', () => switchPage(el.dataset.page));
    });

    /* ============================================================
       SIDEBAR TOGGLE
    ============================================================ */
    const sidebar     = document.getElementById('sidebar');
    const mainContent = document.getElementById('mainContent');
    const topbar      = document.getElementById('topbar');
    const overlay     = document.getElementById('sidebarOverlay');

    document.getElementById('toggleSidebar').addEventListener('click', () => {
        if (window.innerWidth < 992) {
            openMobileSidebar();
        } else {
            sidebar.classList.toggle('collapsed');
            mainContent.classList.toggle('collapsed');
            topbar.classList.toggle('collapsed');
        }
    });

    function openMobileSidebar() {
        sidebar.classList.add('mobile-open');
        overlay.style.display = 'block';
        requestAnimationFrame(() => overlay.style.opacity = '1');
    }
    function closeMobileSidebar() {
        sidebar.classList.remove('mobile-open');
        overlay.style.opacity = '0';
        setTimeout(() => { overlay.style.display = 'none'; }, 300);
    }
    overlay.addEventListener('click', closeMobileSidebar);

