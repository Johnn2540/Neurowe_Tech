<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // ---------- REAL-TIME API FETCHING ----------
    const API_BASE = ''; // relative to current origin
    
    function showToast(msg, type='success') { const c=document.getElementById('toastContainer'); const d=document.createElement('div'); d.className=`toast-item ${type}`; d.innerHTML=msg; c.appendChild(d); setTimeout(()=>d.remove(),3000); }
    
    async function apiFetch(endpoint, options={}) {
        try {
            const res = await fetch(endpoint, { headers: { 'Content-Type': 'application/json' }, ...options });
            const json = await res.json();
            if (!res.ok) throw new Error(json.message || 'Request failed');
            return json;
        } catch(e) { showToast(e.message, 'error'); return null; }
    }

    // Load dashboard stats
    async function loadDashboardStats() {
        const [users, projects, contacts, subs] = await Promise.all([
            apiFetch('/api/admin/users'), apiFetch('/api/projects'), apiFetch('/api/contacts'), apiFetch('/api/subscribers')
        ]);
        const userCount = users?.users?.length || 0;
        const projectCount = projects?.projects?.length || 0;
        const contactCount = (contacts?.contacts?.length) || 0;
        const subCount = (subs?.subscribers?.length) || 0;
        document.getElementById('statUsers').innerText = userCount;
        document.getElementById('statProjects').innerText = projectCount;
        document.getElementById('statContacts').innerText = contactCount;
        document.getElementById('statSubscribers').innerText = subCount;
        document.getElementById('usersBadge').innerText = userCount;
        document.getElementById('contactsBadge').innerText = contactCount;
        
        // recent contacts preview
        const recent = (contacts?.contacts || []).slice(0,3);
        const dashBody = document.getElementById('dashContactsBody');
        if(recent.length) dashBody.innerHTML = recent.map(c => `<tr><td><span class="fw-600">${c.name}</span></td><td><span class="badge-pill bp-blue">${c.project_type || 'General'}</span></td><td>${new Date(c.created_at).toLocaleDateString()}</td><td><span class="badge-pill bp-orange">New</span></td></tr>`).join('');
        else dashBody.innerHTML = '<tr><td colspan="4" class="text-center">No messages</td></tr>';
        
        // activity feed simulation from contacts/users
        const actContainer = document.getElementById('activityFeed');
        if(actContainer) actContainer.innerHTML = (contacts?.contacts?.slice(0,2).map(c => `<div class="activity-item"><div><i class="fas fa-envelope"></i></div><div><p>New contact: ${c.name}</p><span>${new Date(c.created_at).toLocaleString()}</span></div></div>`).join('')) || '<div class="text-muted">No recent activity</div>';
    }
    
    async function loadUsersTable() { const data = await apiFetch('/api/admin/users'); const tbody = document.getElementById('usersTableBody'); if(data?.users) tbody.innerHTML = data.users.map(u => `<tr><td><div class="fw-600">${u.username}</div></td><td>${u.email}</td><td><span class="badge-pill ${u.role==='admin'?'bp-purple':'bp-blue'}">${u.role}</span></td><td><span class="badge-pill ${u.is_active?'bp-green':'bp-yellow'}">${u.is_active?'Active':'Inactive'}</span></td><td><button class="act-btn act-edit" onclick="toggleAdminRole(${u.id}, '${u.role}')"><i class="fas fa-shield-halved"></i></button> <button class="act-btn act-delete" onclick="deleteUser(${u.id})"><i class="fas fa-trash"></i></button></td></tr>`).join(''); }
    async function loadProjectsTable() { const data = await apiFetch('/api/projects'); const tbody = document.getElementById('projectsTableBody'); if(data?.projects) tbody.innerHTML = data.projects.map(p => `<tr><td class="fw-600">${p.name}</td><td>${p.category||'Web'}</td><td><span class="badge-pill ${p.featured?'bp-green':'bp-yellow'}">${p.featured?'Yes':'No'}</span></td><td><button class="act-btn act-delete" onclick="deleteProject(${p.id})"><i class="fas fa-trash"></i></button></td></tr>`).join(''); }
    async function loadContactsTable() { const data = await apiFetch('/api/contacts'); const tbody = document.getElementById('contactsTableBody'); if(data?.contacts) tbody.innerHTML = data.contacts.map(c => `<tr><td class="fw-600">${c.name}</td><td>${c.email}</td><td>${c.project_type||'N/A'}</td><td>${new Date(c.created_at).toLocaleDateString()}</td><td><button class="act-btn act-delete" onclick="deleteContact(${c.id})"><i class="fas fa-trash"></i></button></td></tr>`).join(''); }
    async function loadSubscribersTable() { const data = await apiFetch('/api/subscribers'); const tbody = document.getElementById('subscribersTableBody'); if(data?.subscribers) tbody.innerHTML = data.subscribers.map(s => `<tr><td>${s.email}</td><td>${new Date(s.subscribed_at).toLocaleDateString()}</td><td><button class="act-btn act-delete" onclick="deleteSubscriber(${s.id})"><i class="fas fa-trash"></i></button></td></tr>`).join(''); }
    
    // mock load for other tables (can be extended)
    function loadBlogTable() { document.getElementById('blogTableBody').innerHTML = '<tr><td class="text-muted">Blog management coming soon</td></tr>'; }
    function loadServicesTable() { document.getElementById('servicesTableBody').innerHTML = '<tr><td class="text-muted">Service management UI ready for backend integration</td></tr>'; }
    function loadPortfolioTable() { document.getElementById('portfolioTableBody').innerHTML = '<tr><td class="text-muted">Portfolio items sync with projects</td></tr>'; }
    function loadTestimonialsTable() { document.getElementById('testimonialsTableBody').innerHTML = '<tr><td class="text-muted">Testimonials can be managed</td></tr>'; }
    function loadTeamTable() { document.getElementById('teamTableBody').innerHTML = '<tr><td class="text-muted">Team profiles CRUD ready</td></tr>'; }
    function loadPricingTable() { document.getElementById('pricingTableBody').innerHTML = '<tr><td class="text-muted">Pricing plans integrate with backend</td></tr>'; }
    
    // CRUD actions
    async function createUser() { const name=document.getElementById('newUserName').value, email=document.getElementById('newUserEmail').value, pwd=document.getElementById('newUserPassword').value; if(!name||!email) return showToast('Fill fields','error'); const res=await apiFetch('/api/signup',{method:'POST',body:JSON.stringify({fullname:name,email,password:pwd})}); if(res?.success){ showToast('User created'); bootstrap.Modal.getInstance(document.getElementById('addUserModal')).hide(); loadUsersTable(); loadDashboardStats(); } }
    async function createProject() { const name=document.getElementById('projectName').value, category=document.getElementById('projectCategory').value; if(!name) return; const res=await apiFetch('/api/projects',{method:'POST',body:JSON.stringify({name,category})}); if(res?.success){ showToast('Project added'); loadProjectsTable(); loadDashboardStats(); } }
    async function createBlog() { showToast('Blog post feature demo','info'); }
    async function deleteUser(id) { if(confirm('Delete user?')){ const res=await apiFetch(`/api/admin/delete-user/${id}`,{method:'DELETE'}); if(res?.success){ showToast('User deleted'); loadUsersTable(); loadDashboardStats(); } } }
    async function deleteProject(id) { if(confirm('Delete project?')){ const res=await apiFetch(`/api/projects/${id}`,{method:'DELETE'}); if(res?.success){ loadProjectsTable(); loadDashboardStats(); } } }
    async function deleteContact(id) { if(confirm('Delete message?')){ const res=await apiFetch(`/api/contacts/${id}`,{method:'DELETE'}); if(res?.success){ loadContactsTable(); loadDashboardStats(); } } }
    async function deleteSubscriber(id) { if(confirm('Delete subscriber?')){ const res=await apiFetch(`/api/subscribers/${id}`,{method:'DELETE'}); if(res?.success){ loadSubscribersTable(); loadDashboardStats(); } } }
    async function toggleAdminRole(userId, currentRole) { const endpoint = currentRole === 'admin' ? '/api/admin/remove-admin' : '/api/admin/make-admin'; const res=await apiFetch(endpoint,{method:'POST',body:JSON.stringify({userId})}); if(res?.success){ showToast(`Role updated`); loadUsersTable(); } }
    
    // Charts initialization
    let growthChart, donutChart, visitorChart;
    function initCharts() { growthChart = new Chart(document.getElementById('growthChart'),{type:'line',data:{labels:['Jan','Feb','Mar','Apr','May','Jun'],datasets:[{label:'Total Users',data:[0,0,0,0,0,0],borderColor:'#3b82f6'},{label:'Subscribers',data:[0,0,0,0,0,0],borderColor:'#a855f7'}]}}); donutChart = new Chart(document.getElementById('donutChart'),{type:'doughnut',data:{labels:['Direct','WhatsApp','Organic'],datasets:[{data:[34,28,22],backgroundColor:['#3b82f6','#25D366','#22c55e']}]}}); visitorChart = new Chart(document.getElementById('visitorChart'),{type:'bar',data:{labels:['Week 1','Week 2','Week 3','Week 4'],datasets:[{label:'Page Views',data:[0,0,0,0],backgroundColor:'#3b82f6'}]}}); }
    async function updateCharts() { const usersData = await apiFetch('/api/admin/users'); const subsData = await apiFetch('/api/subscribers'); const userCount = usersData?.users?.length || 0; const subCount = subsData?.subscribers?.length || 0; if(growthChart){ growthChart.data.datasets[0].data = [Math.max(0,userCount-12),Math.max(0,userCount-8),Math.max(0,userCount-4),userCount-2,userCount-1,userCount]; growthChart.data.datasets[1].data = [Math.max(0,subCount-30),Math.max(0,subCount-20),Math.max(0,subCount-12),subCount-8,subCount-4,subCount]; growthChart.update(); } if(visitorChart) visitorChart.data.datasets[0].data = [420,580,720,890]; visitorChart?.update(); }
    
    // Navigation & refresh
    const pages = ['dashboard','analytics','users','projects','contacts','subscribers','blog','services','portfolio','testimonials','team','pricing','settings'];
    function switchPage(page) { pages.forEach(p => document.getElementById(p+'Page').classList.remove('active')); document.getElementById(page+'Page').classList.add('active'); document.querySelectorAll('.nav-item[data-page]').forEach(n => n.classList.toggle('active', n.dataset.page === page)); document.getElementById('pageTitle').innerText = page.charAt(0).toUpperCase()+page.slice(1); }
    document.querySelectorAll('.nav-item[data-page]').forEach(el => el.addEventListener('click',()=>switchPage(el.dataset.page)));
    document.getElementById('refreshBtn').addEventListener('click',()=>{ loadDashboardStats(); loadUsersTable(); loadProjectsTable(); loadContactsTable(); loadSubscribersTable(); updateCharts(); showToast('Data refreshed','success'); });
    document.getElementById('sidebarToggle').addEventListener('click',()=>{ document.getElementById('sidebar').classList.toggle('collapsed'); document.getElementById('mainContent').classList.toggle('expanded'); document.getElementById('topbar').classList.toggle('expanded'); });
    function openAddUserModal() { new bootstrap.Modal(document.getElementById('addUserModal')).show(); }
    function openAddProjectModal() { new bootstrap.Modal(document.getElementById('addProjectModal')).show(); }
    function openAddBlogModal() { new bootstrap.Modal(document.getElementById('addBlogModal')).show(); }
    
    // Save settings
    document.getElementById('saveSettingsBtn')?.addEventListener('click',()=>{ showToast('Settings saved (demo)','success'); });
    
    // Load all tables on page load, and initial data
    window.addEventListener('load',()=>{ initCharts(); loadDashboardStats(); loadUsersTable(); loadProjectsTable(); loadContactsTable(); loadSubscribersTable(); loadBlogTable(); loadServicesTable(); loadPortfolioTable(); loadTestimonialsTable(); loadTeamTable(); loadPricingTable(); updateCharts(); setInterval(()=>{ loadDashboardStats(); updateCharts(); }, 30000); });
</script>
</body>
</html>