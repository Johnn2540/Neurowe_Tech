    let allUsers = [];

    async function loadUsersTable() {
        const data = await apiFetch('/api/admin/users');
        allUsers = data?.users || [];
        renderUsersTable(allUsers);
    }

    function renderUsersTable(users) {
        const tb = document.getElementById('usersTableBody');
        if (!tb) return;
        tb.innerHTML = users.length
            ? users.map(u => `
                <tr>
                    <td><div class="td-name">${esc(u.username)}</div></td>
                    <td>${esc(u.email)}</td>
                    <td><span class="pill ${u.role==='admin' ? 'pill-orange' : 'pill-blue'}">${esc(u.role)}</span></td>
                    <td><span class="pill ${u.is_active ? 'pill-green' : 'pill-dim'}">${u.is_active ? 'Active' : 'Inactive'}</span></td>
                    <td>${fmt(u.created_at)}</td>
                    <td>${u.last_login ? fmt(u.last_login) : '<span style="color:var(--text-dim)">Never</span>'}</td>
                    <td>
                        <button class="act-btn act-shield" onclick="toggleRole(${u.id},'${u.role}')" title="${u.role==='admin'?'Remove admin':'Make admin'}"><i class="fas fa-shield-halved"></i></button>
                        <button class="act-btn act-del" onclick="deleteUser(${u.id})" title="Delete user"><i class="fas fa-trash"></i></button>
                    </td>
                </tr>`).join('')
            : `<tr><td colspan="7"><div class="empty-state"><i class="fas fa-users"></i><p>No users found</p></div></td></tr>`;
    }

    function filterUsers(q) {
        const filtered = allUsers.filter(u =>
            u.username.toLowerCase().includes(q.toLowerCase()) ||
            u.email.toLowerCase().includes(q.toLowerCase())
        );
        renderUsersTable(filtered);
    }

    async function createUser() {
        const name = document.getElementById('newUserName').value.trim();
        const email = document.getElementById('newUserEmail').value.trim();
        const pwd = document.getElementById('newUserPassword').value;
        if (!name || !email || !pwd) return toast('Please fill all fields', 'error');
        const res = await apiFetch('/api/signup', { method: 'POST', body: JSON.stringify({ fullname: name, email, password: pwd }) });
        if (res?.success) {
            toast('User created successfully!');
            closeModal('addUserModal');
            ['newUserName','newUserEmail','newUserPassword'].forEach(id => document.getElementById(id).value = '');
            loadUsersTable(); loadDashboard();
        }
    }

    async function deleteUser(id) {
        if (!confirm('Delete this user? This action cannot be undone.')) return;
        const res = await apiFetch(`/api/admin/delete-user/${id}`, { method: 'DELETE' });
        if (res?.success) { toast('User deleted'); loadUsersTable(); loadDashboard(); }
    }

    async function toggleRole(id, currentRole) {
        const ep = currentRole === 'admin' ? '/api/admin/remove-admin' : '/api/admin/make-admin';
