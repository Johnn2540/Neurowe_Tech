            color: var(--text);
            overflow-x: hidden;
        }
        h1, h2, h3, h4, h5 { font-family: var(--font-head); }

        /* Navbar */
        .navbar {
            background: rgba(255,255,255,0.98);
            backdrop-filter: blur(16px);
            box-shadow: 0 2px 20px rgba(0,0,0,0.05);
            padding: 0.8rem 0;
            transition: var(--transition);
        }
        .navbar.scrolled { padding: 0.5rem 0; }
        .navbar-brand {
            font-size: 1.5rem;
            font-weight: 800;
            background: var(--grad-blue);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        .navbar-brand span { color: var(--orange); background: none; }
        .nav-link {
            font-weight: 500;
            color: var(--text) !important;
            transition: var(--transition);
        }
        .nav-link:hover { color: var(--blue) !important; }

        /* Page Header */
