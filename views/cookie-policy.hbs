    <style>
        :root {
            --blue: #2563eb;
            --orange: #f97316;
            --dark: #050b18;
            --dark-2: #0d1526;
            --light: #f8fafc;
            --light-2: #e2e8f0;
            --text: #334155;
            --text-light: #94a3b8;
