            position: relative;
            cursor: pointer;
            transition: var(--transition);
        }
        .toggle-checkbox.active {
            background: var(--blue);
        }
        .toggle-checkbox::after {
            content: '';
            position: absolute;
            width: 22px;
            height: 22px;
            background: white;
            border-radius: 50%;
            top: 2px;
            left: 3px;
            transition: var(--transition);
